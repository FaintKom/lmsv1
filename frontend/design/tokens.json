{
  "$schema": "https://design-tokens.org/schema/v1.json",
  "meta": {
    "name": "GrassLMS — Lively",
    "version": "1.0.0",
    "updated": "2026-05-04",
    "source": "LMS Assignments Redesign.html + Design System.html",
    "themes": ["light"],
    "notes": "Light only. Dark theme is intentionally NOT supported in v1. Brand: one green + sun yellow + coral. Signature: shadow-pop button physics."
  },

  "color": {
    "green": {
      "25":  "#f4fbef",
      "50":  "#ecf9e7",
      "100": "#d4f1c4",
      "200": "#b6e69e",
      "300": "#8fd770",
      "400": "#6bc44d",
      "500": "#3fb04b",
      "600": "#0a8754",
      "700": "#07683f",
      "800": "#054d2f",
      "900": "#0a3d24"
    },
    "sun": {
      "50":  "#fffbe5",
      "100": "#fff2b3",
      "300": "#ffe066",
      "400": "#ffd84d",
      "500": "#f5b800",
      "700": "#7a5500"
    },
    "coral": {
      "50":  "#fff0eb",
      "300": "#ffae9a",
      "500": "#ff7a5c",
      "700": "#c33d22"
    },
    "ink": {
      "50":  "#f4f5f1",
      "100": "#e6e8e4",
      "200": "#c9cec9",
      "300": "#9aa39d",
      "400": "#6b7a70",
      "500": "#4d5a51",
      "700": "#1a2a1f",
      "900": "#0a1a10"
    },
    "paper":   "#fafbf6",
    "paper-2": "#ffffff",
    "info":    "#2b91ff"
  },

  "semantic": {
    "primary":         "{color.green.600}",
    "primary-hover":   "{color.green.700}",
    "primary-soft":    "{color.green.100}",
    "primary-fg":      "#ffffff",

    "success":         "{color.green.600}",
    "success-soft":    "{color.green.50}",
    "success-fg":      "{color.green.800}",

    "warning":         "{color.sun.500}",
    "warning-soft":    "{color.sun.50}",
    "warning-fg":      "{color.sun.700}",

    "danger":          "{color.coral.500}",
    "danger-soft":     "{color.coral.50}",
    "danger-fg":       "{color.coral.700}",

    "info":            "{color.info}",
    "info-soft":       "#e6f2ff",
    "info-fg":         "#0a3a7a",

    "bg":              "{color.paper}",
    "surface":         "{color.paper-2}",
    "surface-2":       "{color.ink.50}",

    "text":            "{color.ink.900}",
    "text-muted":      "{color.ink.500}",
    "text-subtle":     "{color.ink.400}",
    "text-inverse":    "#ffffff",

    "border":          "{color.ink.100}",
    "border-strong":   "{color.ink.200}",
    "border-focus":    "{color.green.500}"
  },

  "radius": {
    "xs":   "6px",
    "sm":   "10px",
    "md":   "14px",
    "lg":   "18px",
    "xl":   "24px",
    "pill": "999px"
  },

  "spacing": {
    "1":  "4px",
    "2":  "8px",
    "3":  "12px",
    "4":  "16px",
    "5":  "20px",
    "6":  "24px",
    "8":  "32px",
    "10": "40px",
    "12": "48px",
    "16": "64px",
    "20": "80px"
  },

  "shadow": {
    "xs":  "0 1px 2px rgba(10, 26, 16, 0.05)",
    "sm":  "0 2px 6px -1px rgba(10, 26, 16, 0.07)",
    "md":  "0 8px 24px -8px rgba(10, 26, 16, 0.12)",
    "lg":  "0 18px 50px -20px rgba(10, 26, 16, 0.18)",
    "pop":         "0 4px 0 0 {color.green.700}",
    "pop-coral":   "0 4px 0 0 {color.coral.700}",
    "pop-sun":     "0 4px 0 0 {color.sun.500}",
    "pop-ink":     "0 4px 0 0 {color.ink.700}"
  },

  "typography": {
    "font": {
      "sans":  "'Manrope', system-ui, -apple-system, sans-serif",
      "mono":  "'Geist Mono', ui-monospace, SFMono-Regular, monospace"
    },
    "size": {
      "xs":   "12px",
      "sm":   "13px",
      "base": "15px",
      "md":   "17px",
      "lg":   "20px",
      "xl":   "24px",
      "2xl":  "32px",
      "3xl":  "44px",
      "4xl":  "60px",
      "5xl":  "80px"
    },
    "weight": {
      "regular":  400,
      "medium":   500,
      "semibold": 600,
      "bold":     700,
      "black":    800
    },
    "scale": {
      "display":  { "size": "64px", "weight": 800, "line": 0.95, "tracking": "-0.035em" },
      "h1":       { "size": "40px", "weight": 800, "line": 1.05, "tracking": "-0.025em" },
      "h2":       { "size": "28px", "weight": 700, "line": 1.15, "tracking": "-0.02em"  },
      "h3":       { "size": "22px", "weight": 700, "line": 1.25, "tracking": "0"        },
      "body-lg":  { "size": "18px", "weight": 500, "line": 1.5,  "tracking": "0"        },
      "body":     { "size": "15px", "weight": 500, "line": 1.55, "tracking": "0"        },
      "body-sm":  { "size": "13px", "weight": 400, "line": 1.5,  "tracking": "0"        },
      "mono":     { "size": "12px", "weight": 500, "line": 1.4,  "tracking": "0.06em", "case": "uppercase", "family": "mono" }
    }
  },

  "motion": {
    "fast":   "120ms",
    "base":   "200ms",
    "slow":   "400ms",
    "ease":   "cubic-bezier(0.2, 0.8, 0.2, 1)"
  }
}
