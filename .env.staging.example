# === GrassLMS — STAGING environment (lives on the same VPS as prod) ===
# Copy this to .env.staging on the prod server (in /opt/lms-staging) and fill in.
# DO NOT reuse prod values — staging must have its own DB password and JWT secret
# so a staging compromise can't read prod data.

# Tag this stack so the backend logger / Sentry knows it's staging.
ENVIRONMENT=staging

# Database (separate from prod — different name, different password, different volume)
POSTGRES_DB=lms_staging
POSTGRES_USER=lms_staging
POSTGRES_PASSWORD=CHANGE_ME_GENERATE_NEW_RANDOM
DATABASE_URL=postgresql+asyncpg://lms_staging:CHANGE_ME_GENERATE_NEW_RANDOM@staging-db:5432/lms_staging

# JWT — generate a different secret than prod so prod tokens are not valid here.
# python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=CHANGE_ME_NEW_64_CHAR_HEX
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Super admin bootstrap — a staging-only account so testers can log in.
# Use a different email so you don't confuse staging with prod sessions.
SUPER_ADMIN_EMAIL=admin@staging.grasslms.online
SUPER_ADMIN_PASSWORD=CHANGE_ME

# CORS / public URL
CORS_ORIGINS=https://staging.grasslms.online
APP_URL=https://staging.grasslms.online

# Sandbox
SANDBOX_URL=http://staging-sandbox:8001

# === Optional services — leave empty by default ===

# Stripe — staging should use Stripe TEST keys, not live.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Lemon Squeezy — leave empty for staging unless you wire a separate test store.
LEMONSQUEEZY_API_KEY=
LEMONSQUEEZY_STORE_ID=
LEMONSQUEEZY_WEBHOOK_SECRET=

# Email — recommended OFF for staging so test signups don't spam real inboxes.
EMAIL_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=staging@grasslms.online
EMAIL_FROM_NAME=GrassLMS Staging
REQUIRE_EMAIL_VERIFICATION=false

# Sentry — separate Sentry project for staging so you can filter noise from prod.
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# Logging
LOG_LEVEL=DEBUG
LOG_JSON=true

# Redis (rate limiter + cache) — points at the staging-redis container.
REDIS_URL=redis://staging-redis:6379/0
RATE_LIMIT_STORAGE_URI=redis://staging-redis:6379/0

# Demo mode — useful on staging for quick UI walkthroughs.
DEMO_MODE_ENABLED=true
DEMO_STUDENT_EMAIL=student@staging.grasslms.online
DEMO_TEACHER_EMAIL=teacher@staging.grasslms.online

# File storage — local disk inside the container, separate volume.
STORAGE_BACKEND=local

# OAuth — empty unless you wire dedicated test apps in Zoom / Google / Microsoft.
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
ZOOM_REDIRECT_URI=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_REDIRECT_URI=
MICROSOFT_TENANT_ID=
YOUTUBE_API_KEY=

# App
APP_NAME=GrassLMS Staging
DEBUG=false
