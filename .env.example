# === LearnHub LMS — Production Environment ===
# Copy this to .env and fill in values, or use deploy.bat to auto-generate

# Environment: development | staging | production
# In production the server refuses to start if JWT_SECRET is default or DEBUG=true.
ENVIRONMENT=development

# Database
POSTGRES_DB=lms
POSTGRES_USER=lms
POSTGRES_PASSWORD=CHANGE_ME_RANDOM_PASSWORD
DATABASE_URL=postgresql+asyncpg://lms:CHANGE_ME_RANDOM_PASSWORD@db:5432/lms

# JWT Authentication
# REQUIRED in production: generate with `python -c "import secrets; print(secrets.token_hex(32))"`
JWT_SECRET=CHANGE_ME_RANDOM_64_CHAR_HEX
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Super admin bootstrap (optional, used only on first startup to create the first admin).
# If either is empty, no super admin is created — existing admins are untouched.
# Leave empty after the first admin exists; rotate password via the app, not env.
SUPER_ADMIN_EMAIL=
SUPER_ADMIN_PASSWORD=

# CORS (comma-separated origins, updated by deploy.bat after tunnel starts)
CORS_ORIGINS=http://localhost:3000

# Sandbox
SANDBOX_URL=http://sandbox:8001

# Stripe (optional, leave empty for demo)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Sentry error tracking (optional, empty DSN disables Sentry)
# Backend:
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
# Frontend (browser needs NEXT_PUBLIC_ prefix; separate DSN recommended):
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1

# App
APP_NAME=LearnHub
DEBUG=false
