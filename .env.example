# === GrassLMS — Production Environment ===
# Copy this to .env and fill in values, or use deploy.bat to auto-generate

# Environment: development | staging | production
# In production the server refuses to start if JWT_SECRET is default or DEBUG=true.
ENVIRONMENT=development

# Database
POSTGRES_DB=lms
POSTGRES_USER=lms
POSTGRES_PASSWORD=CHANGE_ME_RANDOM_PASSWORD
DATABASE_URL=postgresql+asyncpg://lms:CHANGE_ME_RANDOM_PASSWORD@db:5432/lms

# JWT Authentication
# REQUIRED in production: generate with `python -c "import secrets; print(secrets.token_hex(32))"`
JWT_SECRET=CHANGE_ME_RANDOM_64_CHAR_HEX
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Super admin bootstrap (optional, used only on first startup to create the first admin).
# If either is empty, no super admin is created — existing admins are untouched.
# Leave empty after the first admin exists; rotate password via the app, not env.
SUPER_ADMIN_EMAIL=
SUPER_ADMIN_PASSWORD=

# CORS (comma-separated origins, updated by deploy.bat after tunnel starts)
CORS_ORIGINS=http://localhost:3000

# Sandbox
SANDBOX_URL=http://sandbox:8001

# Stripe (optional, leave empty for demo)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Sentry error tracking (optional, empty DSN disables Sentry)
# Backend:
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
# Frontend (browser needs NEXT_PUBLIC_ prefix; separate DSN recommended):
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1

# Demo mode — exposes POST /auth/demo-login and unlocks the /demo landing page.
# Flip to true ONLY after seeding the demo org once:
#     docker compose -f docker-compose.prod.yml exec backend \
#         python scripts/seed_demo_org.py
# Otherwise the endpoint returns 400 ("Demo account is not available").
DEMO_MODE_ENABLED=false
DEMO_STUDENT_EMAIL=demo-student@grasslms.online
DEMO_TEACHER_EMAIL=demo-teacher@grasslms.online

# App
APP_NAME=GrassLMS
DEBUG=false

# === Optional integrations (leave empty to disable) ===

# Knowledge module (RAG): Voyage AI embeddings. Without this, semantic search
# in the knowledge module is unavailable. Read from the environment directly.
VOYAGE_API_KEY=

# Rate-limiter storage. Default memory:// does NOT work across multiple workers
# (each worker keeps its own counters). In production set this to the Redis URL.
RATE_LIMIT_STORAGE_URI=
REDIS_URL=

# Email / SMTP (Brevo in prod). EMAIL_ENABLED=false disables all sends.
EMAIL_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@grasslms.online
EMAIL_FROM_NAME=GrassLMS

# Object storage for uploads. local = on-disk; s3 = S3/R2-compatible bucket.
STORAGE_BACKEND=local
S3_BUCKET=
S3_ENDPOINT_URL=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_REGION=auto
S3_PUBLIC_URL_BASE=
